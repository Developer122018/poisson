    "    \"ax = plt.axes(projection=\\\"3D\\\")\\n\",\n",
    "    \"ax.plot_surface(predictions[\\\"\\\"], predictions[\\\"\\\"], predictions[\\\"\\\"], cmap=\\\"viridis\\\", edgecolor=\\\"green\\\")\\n\",\n",
    "    \"ax.set_title(\\\"Surface Plot\\\")\\n\",\n",
    "    \"plt.show()\"\n",
    "   ],\n",
