    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": [\n",
    "    \"# Elo Model\\n\",\n",
    "    \"\\n\",\n",
    "    \"### Prediction and Update Formulae\\n\",\n",
    "    \"\\n\",\n",
    "    \"Outcomes are given as a number from $0$ to $1$, where $0$ means the player/team on the left lost whilst $1$ means they won. If the outcome is $0.5$, we have a draw, and any number in between represents a win probability.\"\n",
    "   ],\n",
    "   \"id\": \"67b9a8500a3782d2\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-18T20:36:58.291037Z\",\n",
    "     \"start_time\": \"2026-03-18T20:36:58.281141Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"def expected_outcome(elo_a: float, elo_b: float, scale: int = 400) -> float:\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    :param elo_a: First team's elo.\\n\",\n",
    "    \"    :param elo_b: Second team's elo.\\n\",\n",
    "    \"    :param scale: Elo difference between players to give 10:1 odds to the higher player.\\n\",\n",
    "    \"    :return: Chance of player A winning the game.\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    rb_ra: float = (elo_b - elo_a) / scale\\n\",\n",
    "    \"    return 1 / (1 + 10 ** rb_ra)\"\n",
    "   ],\n",
    "   \"id\": \"5088087d85865b24\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 57\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-18T20:36:58.322693Z\",\n",
    "     \"start_time\": \"2026-03-18T20:36:58.305324Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"def new_elos(elo_a: float, elo_b: float, outcome: float, k_factor: int = 16) -> tuple[float, float]:\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    :param elo_a: First team's elo.\\n\",\n",
    "    \"    :param elo_b: Second team's elo.\\n\",\n",
    "    \"    :param outcome: Which player won. Traditionally it is a simple win/loss, but we use a float that gives information on the margin of victory as well (the fraction of points scored by the first team).\\n\",\n",
    "    \"    :param k_factor: Maximum elo change allowed after a game, limiting volatility.\\n\",\n",
    "    \"    :return: The updated elos of both players after the game.\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    diff: float = k_factor * (outcome - expected_outcome(elo_a, elo_b))\\n\",\n",
    "    \"    return elo_a + diff, elo_b - diff\"\n",
    "   ],\n",
    "   \"id\": \"b4f10c5f4358e576\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 58\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-18T20:36:58.335394Z\",\n",
    "     \"start_time\": \"2026-03-18T20:36:58.328526Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"def kelly_criterion(probability: float, odds: float = 2.0, fraction: float = 1.0) -> float:\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    :param probability: The win probability.\\n\",\n",
    "    \"    :param odds: Given odds for the team to win. By default, we consider the odds to be even (for backtesting).\\n\",\n",
    "    \"    :param fraction: What fraction of the Kelly formula's output to bet.\\n\",\n",
    "    \"    :return: The percentage of the account to bet. With even odds, this is 2p - 1.\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    return fraction * (probability - (1 - probability) / (odds - 1))\"\n",
    "   ],\n",
    "   \"id\": \"32b1da32783a22dc\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 59\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": [\n",
    "    \"### Load Data\\n\",\n",
    "    \"\\n\",\n",
    "    \"First cell formats the raw data and extracts the teams, second cell splits data into training and test.\"\n",
    "   ],\n",
    "   \"id\": \"cb9c9ae3c996995\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-18T20:36:58.353895Z\",\n",
    "     \"start_time\": \"2026-03-18T20:36:58.335967Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"from pandas import DataFrame, Series\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"\\n\",\n",
    "    \"raw: DataFrame = pd.read_csv(\\\"data/nba_team_reference.csv\\\")\\n\",\n",
    "    \"raw[\\\"points_ratio\\\"] = raw[\\\"pts_home\\\"] / (raw[\\\"pts_home\\\"] + raw[\\\"pts_away\\\"]) # Tells us which team won and by how much (ratio < 0.5 means home team lost).\\n\",\n",
    "    \"raw.drop(columns=[\\\"season_year\\\", \\\"team_id_home\\\", \\\"team_id_away\\\", \\\"pts_home\\\", \\\"pts_away\\\", \\\"home_win\\\"], inplace=True) # Formatting the data...\\n\",\n",
    "    \"raw.rename(columns={\\\"game_id\\\": \\\"id\\\", \\\"game_date\\\": \\\"date\\\", \\\"team_abbreviation_home\\\": \\\"home\\\", \\\"team_abbreviation_away\\\": \\\"away\\\"}, inplace=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"teams: dict[str, float] = dict((team, 1000) for team in set(raw[\\\"home\\\"].tolist() + raw[\\\"away\\\"].tolist())) # Retrieve all team identifiers and start at 1000 elo.\\n\",\n",
    "    \"\\n\",\n",
    "    \"assert len(teams) == 30 # NBA has 30 teams.\"\n",
    "   ],\n",
    "   \"id\": \"b6f2ac3afbf95e50\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 60\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-18T20:36:58.371765Z\",\n",
    "     \"start_time\": \"2026-03-18T20:36:58.354443Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"# Split data into training (random 80% of games) and test (the remaining 20%). Games will be processed in date order.\\n\",\n",
    "    \"training: DataFrame = raw.sample(4 * len(raw) // 5).sort_values(by=[\\\"date\\\"])\\n\",\n",
    "    \"test:     DataFrame = raw[~raw[\\\"id\\\"].isin(training[\\\"id\\\"])].sort_values(by=[\\\"date\\\"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"assert len(training) + len(test) == len(raw)                     # Check the total number of games is still the same.\\n\",\n",
    "    \"assert len(test[\\\"id\\\"].isin(training[\\\"id\\\"]).value_counts()) == 1  # Ensure no overlap between training and test games.\"\n",
    "   ],\n",
    "   \"id\": \"c28da4c8e51946dc\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 61\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": [\n",
    "    \"### Train\\n\",\n",
    "    \"\\n\",\n",
    "    \"Go over each game in order and update team elos.\"\n",
    "   ],\n",
    "   \"id\": \"b2c74ea673737df2\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-18T20:36:58.742541Z\",\n",
    "     \"start_time\": \"2026-03-18T20:36:58.372578Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"\\n\",\n",
    "    \"training_elos: dict[str, list[float]] = dict((team, [1000]) for team in set(raw[\\\"home\\\"].tolist() + raw[\\\"away\\\"].tolist()))\\n\",\n",
    "    \"\\n\",\n",
    "    \"for row in training.itertuples():\\n\",\n",
    "    \"    # For each game, calculate the new elos depending on the result and update the old elos.\\n\",\n",
    "    \"    # Using points ratio as opposed to pure win/loss is necessary to ensure strength differences\\n\",\n",
    "    \"    # are accurately judged (a slim margin of victory should not cause a large elo change).\\n\",\n",
    "    \"    new_home, new_away = new_elos(teams[row.home], teams[row.away], row.points_ratio)\\n\",\n",
    "    \"    teams[row.home] = new_home\\n\",\n",
    "    \"    teams[row.away] = new_away\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for team in training_elos:\\n\",\n",
    "    \"        training_elos[team].append(training_elos[team][-1])\\n\",\n",
    "    \"\\n\",\n",
    "    \"    training_elos[row.home][-1] = new_home\\n\",\n",
    "    \"    training_elos[row.away][-1] = new_away\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Show teams by elo.\\n\",\n",
    "    \"print([ team for team in sorted(teams.items(), key=lambda item: item[1], reverse=True) ])\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.figure(figsize=(15, 10))\\n\",\n",
    "    \"plt.title(\\\"Elos of the 30 NFL teams over time\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"for team in training_elos:\\n\",\n",
    "    \"    plt.plot(training_elos[team], label=team)\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.show()\"\n",
    "   ],\n",
    "   \"id\": \"a71bf32d50733fcf\",\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"[('OKC', 1015.8603653921809), ('BOS', 1014.8931548349756), ('CLE', 1013.8822630911443), ('MIN', 1010.6362158227793), ('DEN', 1008.475731159543), ('LAC', 1006.5123558498051), ('NYK', 1005.5478498302913), ('GSW', 1005.4280125920038), ('HOU', 1005.3959268538259), ('IND', 1005.3588761190077), ('MIL', 1004.6721710318483), ('MEM', 1003.7210108973704), ('CHI', 1001.6249858472986), ('LAL', 1001.2242098197108), ('DET', 1000.4865381128067), ('SAC', 1000.3157049786936), ('ORL', 1000.2646674868528), ('MIA', 999.6013795444803), ('DAL', 997.841500820216), ('ATL', 997.6800538817672), ('PHX', 997.2457241352091), ('POR', 995.0748790168204), ('SAS', 993.2854128669633), ('TOR', 992.6644921672296), ('PHI', 992.4851818633865), ('NOP', 989.2522264361513), ('BKN', 988.8078354753413), ('UTA', 985.3293483184848), ('CHA', 983.8265983994024), ('WAS', 982.6053273544093)]\\n\"\n",
    "     ]\n",
    "    },\n",
    "    {\n",
    "     \"data\": {\n",
    "      \"text/plain\": [\n",
    "       \"<Figure size 1500x1000 with 1 Axes>\"\n",
    "      ],\n",
    "      \"image/png\": \"\"\n",
    "     },\n",
    "     \"metadata\": {},\n",
    "     \"output_type\": \"display_data\",\n",
    "     \"jetTransient\": {\n",
    "      \"display_id\": null\n",
    "     }\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 62\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": \"### Backtest\",\n",
    "   \"id\": \"e82255da46679bbe\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-18T20:36:58.829666Z\",\n",
    "     \"start_time\": \"2026-03-18T20:36:58.746509Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"# Calculate expected outcomes and percentage of account to bet for each test game, as well as whether or not the prediction was correct.\\n\",\n",
    "    \"predictions: DataFrame = test.copy() # To avoid editing raw test data.\\n\",\n",
    "    \"predictions[\\\"prob\\\"] = predictions.apply(lambda row: expected_outcome(teams[row[\\\"home\\\"]], teams[row[\\\"away\\\"]]), axis=1)\\n\",\n",
    "    \"predictions.apply(lambda row: kelly_criterion(row[\\\"prob\\\"] if row[\\\"prob\\\"] > 0.5 else (1 - row[\\\"prob\\\"])), axis=1)\\n\",\n",
    "    \"predictions[\\\"kelly_bet\\\"] = predictions.apply(lambda row: kelly_criterion(row[\\\"prob\\\"] if row[\\\"prob\\\"] > 0.5 else (1 - row[\\\"prob\\\"]), fraction=0.25), axis=1)\\n\",\n",
    "    \"predictions[\\\"correct\\\"] = (predictions[\\\"points_ratio\\\"] > 0.5) == (predictions[\\\"prob\\\"] > 0.5)\\n\",\n",
    "    \"\\n\",\n",
    "    \"#  Calculate account balance at each time step.\\n\",\n",
    "    \"balances: list[float] = [ 10_000.0 ]\\n\",\n",
    "    \"for row in predictions.itertuples():\\n\",\n",
    "    \"    balances.append(balances[-1] + balances[-1] * row.kelly_bet * (1 if row.correct else -1))\"\n",
    "   ],\n",
    "   \"id\": \"39624463f9f5281b\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 63\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": \"### Some Graphs To Visualise Model's Decision Making\",\n",
    "   \"id\": \"683c0e8a44a9eb32\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-18T20:40:55.096888Z\",\n",
    "     \"start_time\": \"2026-03-18T20:40:54.800599Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"fig, axs = plt.subplots(1, 3, figsize=(15, 4))\\n\",\n",
    "    \"\\n\",\n",
    "    \"axs[0].plot(predictions.prob)\\n\",\n",
    "    \"axs[0].set_title(\\\"Expected Outcome (0 = home loses, 1 = home wins)\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"axs[1].plot(predictions.kelly_bet)\\n\",\n",
    "    \"axs[1].set_title(\\\"Fraction of Account Bet By The Kelly Criterion\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"axs[2].plot(balances)\\n\",\n",
    "    \"axs[2].set_title(\\\"Account Balance\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\"\n",
    "   ],\n",
    "   \"id\": \"c29e152da22fed96\",\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"data\": {\n",
    "      \"text/plain\": [\n",
    "       \"<Figure size 1500x400 with 3 Axes>\"\n",
    "      ],\n",
    "      \"image/png\": \"\"\n",
    "     },\n",
    "     \"metadata\": {},\n",
    "     \"output_type\": \"display_data\",\n",
    "     \"jetTransient\": {\n",
    "      \"display_id\": null\n",
    "     }\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 68\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": \"###  Evaluation Metrics\",\n",
    "   \"id\": \"a10588a2c59abaa5\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-18T20:37:00.047372Z\",\n",
    "     \"start_time\": \"2026-03-18T20:36:59.373224Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"# Calculate win rate and final balance.\\n\",\n",
    "    \"success: dict[bool, int]   = predictions[\\\"correct\\\"].value_counts().to_dict()\\n\",\n",
    "    \"win_rate: float            = 100 * success[True] / (success[True] + success[False])\\n\",\n",
    "    \"ret: float                 = balances[-1] - balances[0]\\n\",\n",
    "    \"returns: float             = ret / balances[0]\\n\",\n",
    "    \"series: Series             = Series(balances).pct_change()\\n\",\n",
    "    \"avg_ret: float             = series.mean() * 100\\n\",\n",
    "    \"stddev_ret: float          = series.std() * 100\\n\",\n",
    "    \"stddev_downside_ret: float = Series(filter(lambda ret: ret < 0, series)).std() * 100\\n\",\n",
    "    \"kurtosis_ret: float        = series.kurtosis()\\n\",\n",
    "    \"\\n\",\n",
    "    \"max_drawdown: tuple[int, float] = (0, 0)\\n\",\n",
    "    \"for i in range(len(balances)):\\n\",\n",
    "    \"    for j in range(i + 1, len(balances)):\\n\",\n",
    "    \"        diff: float = (balances[j] - balances[i]) / balances[i]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if diff < max_drawdown[1]:\\n\",\n",
    "    \"            max_drawdown = (j - i, diff)\\n\",\n",
    "    \"\\n\",\n",
    "    \"sharpe_ratio: float  = avg_ret / stddev_ret\\n\",\n",
    "    \"sortino_ratio: float = avg_ret / stddev_downside_ret\\n\",\n",
    "    \"calmar_ratio: float  = returns / -max_drawdown[1]\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Win Rate: {round(win_rate, 2)}%\\\")\\n\",\n",
    "    \"print(f\\\"Total Return: {round(ret, 2)} ({round(100 * returns, 2)}%)\\\")\\n\",\n",
    "    \"print(f\\\"Mean Bet-To-Bet Return: {round(avg_ret, 2)}%\\\")\\n\",\n",
    "    \"print(f\\\"Volatility (standard deviation) of Bet-To-Bet Returns: {round(stddev_ret, 2)}%\\\")\\n\",\n",
    "    \"print(f\\\"Downside Volatility of Returns: {round(stddev_downside_ret, 2)}%\\\")\\n\",\n",
    "    \"print(f\\\"Kurtosis of Returns: {round(kurtosis_ret, 2)}\\\")\\n\",\n",
    "    \"print(f\\\"Maximum Drawdown: {round(max_drawdown[1] * 100, 2)}% over {max_drawdown[0]} games\\\")\\n\",\n",
    "    \"print(f\\\"Sharpe Ratio: {sharpe_ratio}\\\")\\n\",\n",
    "    \"print(f\\\"Sortino Ratio: {sortino_ratio}\\\")\\n\",\n",
    "    \"print(f\\\"Calmar Ratio: {calmar_ratio}\\\")\"\n",
    "   ],\n",
    "   \"id\": \"449c8872430bd62\",\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
