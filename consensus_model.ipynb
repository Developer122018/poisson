    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"from collections.abc import Callable\\n\",\n",
    "    \"\\n\",\n",
    "    \"from consensus_imports.elo_predict import elo_predict\\n\",\n",
    "    \"from consensus_imports.mc_predict import mc_predict\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\\"\\\"\\\"\\n\",\n",
    "    \"Models is a list of tuples containing a model function (outputs a win probability given a home and away team) and a win rate.\\n\",\n",
    "    \"Fill with any given set of models.\\n\",\n",
    "    \"\\\"\\\"\\\"\\n\",\n",
    "    \"models: list[tuple[Callable[[str, str], float], float]] = [\\n\",\n",
    "    \"    (elo_predict, 0.5561),\\n\",\n",
    "    \"    (mc_predict, 0.544)\\n\",\n",
    "    \"]\\n\",\n",
    "    \"total_win_rate: float = sum(map(lambda model: model[1], models))\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 2\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-18T20:15:20.812081Z\",\n",
    "     \"start_time\": \"2026-03-18T20:15:20.802594Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"def predict(home: str, away: str) -> float:\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    :param home: Home team in a given game.\\n\",\n",
    "    \"    :param away: Away team in a given game.\\n\",\n",
    "    \"    :return:     Weighted average (according to win rates) probability of all models' odds for the home team to win.\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    return sum(map(lambda model: model[0](home, away) * model[1], models))/total_win_rate\"\n",
    "   ],\n",
    "   \"id\": \"78dfaf2cd0cea914\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 3\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-18T20:15:20.822738Z\",\n",
    "     \"start_time\": \"2026-03-18T20:15:20.814138Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"def kelly_criterion(probability: float, odds: float = 2.0, fraction: float = 1.0) -> float:\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    :param probability: The win probability.\\n\",\n",
    "    \"    :param odds: Given odds for the team to win. By default, we consider the odds to be even (for backtesting).\\n\",\n",
    "    \"    :param fraction: What fraction of the Kelly formula's output to bet.\\n\",\n",
    "    \"    :return: The percentage of the account to bet. With even odds, this is 2p - 1.\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    return fraction * (probability - (1 - probability) / (odds - 1))\"\n",
    "   ],\n",
    "   \"id\": \"7650b005ea68fedd\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 4\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-18T20:15:23.037386Z\",\n",
    "     \"start_time\": \"2026-03-18T20:15:20.824361Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"from pandas import DataFrame, Series\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"\\n\",\n",
    "    \"data: DataFrame = pd.read_csv(\\\"data/nba_team_reference.csv\\\")\\n\",\n",
    "    \"data[\\\"points_ratio\\\"] = data[\\\"pts_home\\\"] / (data[\\\"pts_home\\\"] + data[\\\"pts_away\\\"]) # Tells us which team won and by how much (ratio < 0.5 means home team lost).\\n\",\n",
    "    \"data.drop(columns=[\\\"season_year\\\", \\\"team_id_home\\\", \\\"team_id_away\\\", \\\"pts_home\\\", \\\"pts_away\\\", \\\"home_win\\\"], inplace=True) # Formatting the data...\\n\",\n",
    "    \"data.rename(columns={\\\"game_id\\\": \\\"id\\\", \\\"game_date\\\": \\\"date\\\", \\\"team_abbreviation_home\\\": \\\"home\\\", \\\"team_abbreviation_away\\\": \\\"away\\\"}, inplace=True)\"\n",
    "   ],\n",
    "   \"id\": \"e93ce67e39e8dd9d\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 5\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-18T20:15:23.639880Z\",\n",
    "     \"start_time\": \"2026-03-18T20:15:23.040208Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"# Calculate expected outcomes and percentage of account to bet for each test game, as well as whether or not the prediction was correct.\\n\",\n",
    "    \"data[\\\"prob\\\"] = data.apply(lambda row: predict(row[\\\"home\\\"], row[\\\"away\\\"]), axis=1)\\n\",\n",
    "    \"data.apply(lambda row: kelly_criterion(row[\\\"prob\\\"] if row[\\\"prob\\\"] > 0.5 else (1 - row[\\\"prob\\\"])), axis=1)\\n\",\n",
    "    \"data[\\\"kelly_bet\\\"] = data.apply(lambda row: kelly_criterion(row[\\\"prob\\\"] if row[\\\"prob\\\"] > 0.5 else (1 - row[\\\"prob\\\"]), fraction=0.25), axis=1)\\n\",\n",
    "    \"data[\\\"correct\\\"] = (data[\\\"points_ratio\\\"] > 0.5) == (data[\\\"prob\\\"] > 0.5)\\n\",\n",
    "    \"\\n\",\n",
    "    \"#  Calculate account balance at each time step.\\n\",\n",
    "    \"balances: list[float] = [ 10_000.0 ]\\n\",\n",
    "    \"for row in data.itertuples():\\n\",\n",
    "    \"    balances.append(balances[-1] + balances[-1] * row.kelly_bet * (1 if row.correct else -1))\"\n",
    "   ],\n",
