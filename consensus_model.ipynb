    "      \"\\u001B[36mCell\\u001B[39m\\u001B[36m \\u001B[39m\\u001B[32mIn[3]\\u001B[39m\\u001B[32m, line 7\\u001B[39m, in \\u001B[36mpredict.<locals>.<lambda>\\u001B[39m\\u001B[34m(model)\\u001B[39m\\n\\u001B[32m      1\\u001B[39m \\u001B[38;5;28;01mdef\\u001B[39;00m\\u001B[38;5;250m \\u001B[39m\\u001B[34mpredict\\u001B[39m(home: \\u001B[38;5;28mstr\\u001B[39m, away: \\u001B[38;5;28mstr\\u001B[39m) -> \\u001B[38;5;28mfloat\\u001B[39m:\\n\\u001B[32m      2\\u001B[39m \\u001B[38;5;250m    \\u001B[39m\\u001B[33;03m\\\"\\\"\\\"\\u001B[39;00m\\n\\u001B[32m      3\\u001B[39m \\u001B[33;03m    :param home: Home team in a given game.\\u001B[39;00m\\n\\u001B[32m      4\\u001B[39m \\u001B[33;03m    :param away: Away team in a given game.\\u001B[39;00m\\n\\u001B[32m      5\\u001B[39m \\u001B[33;03m    :return:     Weighted average (according to win rates) probability of all models' odds for the home team to win.\\u001B[39;00m\\n\\u001B[32m      6\\u001B[39m \\u001B[33;03m    \\\"\\\"\\\"\\u001B[39;00m\\n\\u001B[32m----> \\u001B[39m\\u001B[32m7\\u001B[39m     \\u001B[38;5;28;01mreturn\\u001B[39;00m \\u001B[38;5;28msum\\u001B[39m(\\u001B[38;5;28mmap\\u001B[39m(\\u001B[38;5;28;01mlambda\\u001B[39;00m model: \\u001B[43mmodel\\u001B[49m\\u001B[43m[\\u001B[49m\\u001B[32;43m0\\u001B[39;49m\\u001B[43m]\\u001B[49m\\u001B[43m(\\u001B[49m\\u001B[43mhome\\u001B[49m\\u001B[43m,\\u001B[49m\\u001B[43m \\u001B[49m\\u001B[43maway\\u001B[49m\\u001B[43m)\\u001B[49m * model[\\u001B[32m1\\u001B[39m], models))/total_win_rate\\n\",\n",
    "      \"\\u001B[36mFile \\u001B[39m\\u001B[32m~/Desktop/axioms-team-ecaw/consensus_imports/mc_predict.py:82\\u001B[39m, in \\u001B[36mmc_predict\\u001B[39m\\u001B[34m(home, away)\\u001B[39m\\n\\u001B[32m     79\\u001B[39m matrix = _load_probs()\\n\\u001B[32m     81\\u001B[39m \\u001B[38;5;28;01mif\\u001B[39;00m home \\u001B[38;5;129;01mnot\\u001B[39;00m \\u001B[38;5;129;01min\\u001B[39;00m matrix:\\n\\u001B[32m---> \\u001B[39m\\u001B[32m82\\u001B[39m     \\u001B[38;5;28;01mraise\\u001B[39;00m \\u001B[38;5;167;01mValueError\\u001B[39;00m(\\u001B[33mf\\u001B[39m\\u001B[33m'\\u001B[39m\\u001B[33mUnknown team \\u001B[39m\\u001B[33m\\\"\\u001B[39m\\u001B[38;5;132;01m{\\u001B[39;00mhome\\u001B[38;5;132;01m}\\u001B[39;00m\\u001B[33m\\\"\\u001B[39m\\u001B[33m. Valid: \\u001B[39m\\u001B[38;5;132;01m{\\u001B[39;00m\\u001B[38;5;28msorted\\u001B[39m(matrix.keys())\\u001B[38;5;132;01m}\\u001B[39;00m\\u001B[33m'\\u001B[39m)\\n\\u001B[32m     83\\u001B[39m \\u001B[38;5;28;01mif\\u001B[39;00m away \\u001B[38;5;129;01mnot\\u001B[39;00m \\u001B[38;5;129;01min\\u001B[39;00m matrix[home]:\\n\\u001B[32m     84\\u001B[39m     \\u001B[38;5;28;01mraise\\u001B[39;00m \\u001B[38;5;167;01mValueError\\u001B[39;00m(\\u001B[33mf\\u001B[39m\\u001B[33m'\\u001B[39m\\u001B[33mUnknown team \\u001B[39m\\u001B[33m\\\"\\u001B[39m\\u001B[38;5;132;01m{\\u001B[39;00maway\\u001B[38;5;132;01m}\\u001B[39;00m\\u001B[33m\\\"\\u001B[39m\\u001B[33m. Valid: \\u001B[39m\\u001B[38;5;132;01m{\\u001B[39;00m\\u001B[38;5;28msorted\\u001B[39m(matrix.keys())\\u001B[38;5;132;01m}\\u001B[39;00m\\u001B[33m'\\u001B[39m)\\n\",\n",
